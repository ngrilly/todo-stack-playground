@inherits RazorSlice<TodoListModel>

@functions {
    private static string FilterBtnClass(bool active) => active ? "btn-sm" : "btn-sm-outline";
}

<div class="flex flex-wrap items-center gap-4 mb-4">
    <span class="text-sm font-medium text-muted-foreground">Filter:</span>
    <div role="group" class="button-group">
        <button
            class="@FilterBtnClass(Model.Filter == "")"
            hx-get="/?filter=&sort=@Model.Sort"
            hx-target="#todo-list"
            hx-swap="innerHTML">All</button>
        <button
            class="@FilterBtnClass(Model.Filter == "todo")"
            hx-get="/?filter=todo&sort=@Model.Sort"
            hx-target="#todo-list"
            hx-swap="innerHTML">Todo</button>
        <button
            class="@FilterBtnClass(Model.Filter == "done")"
            hx-get="/?filter=done&sort=@Model.Sort"
            hx-target="#todo-list"
            hx-swap="innerHTML">Done</button>
    </div>

    <span class="text-sm font-medium text-muted-foreground">Sort:</span>
    <div role="group" class="button-group">
        <button
            class="@FilterBtnClass(Model.Sort == "description")"
            hx-get="/?filter=@Model.Filter&sort=description"
            hx-target="#todo-list"
            hx-swap="innerHTML">Description</button>
        <button
            class="@FilterBtnClass(Model.Sort == "due_date")"
            hx-get="/?filter=@Model.Filter&sort=due_date"
            hx-target="#todo-list"
            hx-swap="innerHTML">Due Date</button>
    </div>
</div>

@if (Model.Todos.Count == 0)
{
    <p class="text-muted-foreground text-center py-8">No todos found.</p>
}
else
{
    <div class="flex flex-col gap-1">
        @foreach (var todo in Model.Todos)
        {
            @(await RenderPartialAsync<TodoItem, TodoItemModel>(new TodoItemModel(todo)))
        }
    </div>
}
